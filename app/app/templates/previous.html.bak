{% extends 'base.html' %}{% block body %}<section class="card"><h2>Previous Results</h2><table><tr><th>Job</th><th>State</th><th>Created</th><th>Open</th><th>Delete</th></tr>{% for id,j in jobs.items() %}<tr><td>{{id}}</td><td>{{j.state}}</td><td>{{j.created}}</td><td><a href="/jobs/{{id}}">status</a> | <a href="/?job={{id}}">dashboard</a></td><td>{% if j.state != 'running' %}<form method="post" action="/previous/{{id}}/delete" onsubmit="return confirm('Delete this previous result?')"><button type="submit">Delete</button></form>{% else %}<small>Running</small>{% endif %}</td></tr>{% else %}<tr><td colspan="5">No previous results.</td></tr>{% endfor %}</table></section>{% endblock %}
