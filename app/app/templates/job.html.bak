{% extends 'base.html' %}{% block body %}<section class="card"><h2>Job Progress</h2><p id="msg">{{job.message if job else ''}}</p><p><b>Overall:</b> <span id="pct">{{job.progress if job else 0}}</span>%</p><div class="bar"><div id="bar" style="width:{{job.progress if job else 0}}%"></div></div><p><b>Current file read:</b> <span id="filepct">{{job.current_file_progress if job else 0}}</span>%</p><div class="bar"><div id="filebar" style="width:{{job.current_file_progress if job else 0}}%"></div></div><p><b>Packets:</b> <span id="packets">{{job.packets if job else 0}}</span></p><p><b>Current file:</b> <span id="file">{{job.current_file if job else ''}}</span></p><pre id="raw">{{ job | tojson(indent=2) }}</pre></section>{% endblock %}{% block scripts %}<script>function clamp(n){n=Number(n||0);return Math.max(0,Math.min(100,Math.round(n)))}async function poll(){let r=await fetch('/api/jobs/{{job_id}}');let j=await r.json();let p=clamp(j.progress);let fp=clamp(j.current_file_progress);document.getElementById('msg').textContent=j.message||j.state||'';document.getElementById('pct').textContent=p;document.getElementById('bar').style.width=p+'%';document.getElementById('filepct').textContent=fp;document.getElementById('filebar').style.width=fp+'%';document.getElementById('packets').textContent=j.packets||0;document.getElementById('file').textContent=j.current_file||'';document.getElementById('raw').textContent=JSON.stringify(j,null,2);if(j.state!=='complete'&&j.state!=='failed')setTimeout(poll,1500)}poll();</script>{% endblock %}
