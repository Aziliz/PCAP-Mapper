<!doctype html><html><head><meta charset="utf-8"><title>PCAP Mapper</title><link rel="stylesheet" href="/static/style.css"></head><body class="dark"><header><h1>PCAP Mapper</h1><nav><a href="/">Dashboard</a><a href="/assets">Assets</a><a href="/communications">Communications</a><a href="/log-sources">Log Sources</a><a href="/events">Events</a><a href="/mitre">MITRE Heat Map</a><a href="/rules">Detection Rules</a><a href="/network-rules">Network Rules</a><a href="/reports">Reports</a><a href="/previous">Previous Results</a></nav><button id="dark">Dark Mode</button></header><main>{% block body %}{% endblock %}</main><script>const b=document.body; const darkBtn=document.getElementById('dark'); function updateThemeButton(){darkBtn.textContent=b.classList.contains('dark')?'Light Mode':'Dark Mode';} if(localStorage.dark==='0')b.classList.remove('dark'); else b.classList.add('dark'); updateThemeButton(); darkBtn.onclick=()=>{b.classList.toggle('dark');localStorage.dark=b.classList.contains('dark')?'1':'0';updateThemeButton();};
(function(){const blocks=[...document.querySelectorAll('.rule-validation-progress')]; if(!blocks.length)return; blocks.forEach(block=>{const job=block.dataset.job; if(!job)return; const bar=block.querySelector('.bar>div'); const pct=block.querySelector('.rv-percent'); const msg=block.querySelector('.rv-message'); const key='rv-reloaded-'+job; async function poll(){try{const r=await fetch('/api/rule-validation/'+job,{cache:'no-store'}); if(!r.ok)return; const d=await r.json(); const p=Math.max(0,Math.min(100,parseInt(d.progress||0))); if(d.status==='running'||p>0){block.style.display='block';} if(d.status==='running'){sessionStorage.removeItem(key);} if(bar)bar.style.width=p+'%'; if(pct)pct.textContent=p+'%'; if(msg)msg.textContent=d.message||d.status||''; if(d.status==='complete'&&sessionStorage.getItem(key)!=='1'){sessionStorage.setItem(key,'1'); location.reload(); return;} if(d.status==='running'){setTimeout(poll,1000);} }catch(e){setTimeout(poll,2000);} } poll();});})();</script>{% block scripts %}{% endblock %}</body></html>
